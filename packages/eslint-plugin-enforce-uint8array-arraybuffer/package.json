{
  "name": "@protontech/eslint-plugin-enforce-uint8array-arraybuffer",
  "version": "3.0.0",
  "description": "This plugin enforces any Uint8Array type declaration to explicitly define an ArrayBuffer as generic type",
  "keywords": [
    "eslint",
    "typescript",
    "typescrypt-eslint",
    "uint8array",
    "arraybuffer"
  ],
  "license": "GPL-3.0",
  "author": "",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "main": "src/index.ts",
  "types": "src/index.ts",
  "files": [
    "src/"
  ],
  "scripts": {
    "test": "node --test ./test/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@typescript-eslint/utils": "^8.43.0"
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^8.43.0",
    "@typescript-eslint/rule-tester": "^8.43.0",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@typescript-eslint/parser": "^8.43.0",
    "typescript": "^6.0.3"
  }
}
