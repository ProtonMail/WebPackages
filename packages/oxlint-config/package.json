{
    "name": "@protontech/oxlint-config",
    "version": "1.1.0",
    "license": "GPL-3.0",
    "author": "Proton AG",
    "type": "module",
    "exports": {
        "./*.ts": "./configs/*.ts"
    },
    "files": [
        "dist/"
    ],
    "scripts": {
        "build": "tsc -p tsconfig.build.json",
        "format": "prettier --write .",
        "prepack": "pnpm run build"
    },
    "devDependencies": {
        "@protontech/eslint-plugin-enforce-uint8array-arraybuffer": "workspace:*",
        "@protontech/prettier-config": "workspace:*",
        "@protontech/typescript-config": "workspace:*",
        "oxlint": "^1.74.0",
        "prettier": "^3.9.5",
        "typescript": "^6.0.3"
    },
    "peerDependencies": {
        "@protontech/eslint-plugin-enforce-uint8array-arraybuffer": "workspace:^",
        "oxlint": "^1.74.0"
    },
    "publishConfig": {
        "exports": {
            "./*.ts": {
                "types": "./dist/*.d.ts",
                "default": "./dist/*.js"
            }
        }
    }
}
